{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "bracketSameLine": false,
  "singleAttributePerLine": true,
  "ignorePatterns": [
    "dist/**",
    ".claude/**",
    "*.md",
    "node_modules/**",
    "src/routeTree.gen.ts",
    "src/generated/**",
    "src/components/ui/**"
  ]
}
